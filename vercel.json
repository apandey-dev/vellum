{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },

    { "source": "/dashboard", "destination": "/index.html" },

    { "source": "/login", "destination": "/auth/login.html" },
    { "source": "/signup", "destination": "/auth/signup.html" },

    { "source": "/share/:id", "destination": "/share.html?id=:id" },

    { "source": "/print", "destination": "/print.html" },

    { "source": "/error", "destination": "/error.html" }
  ]
}
