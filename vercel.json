{
  "cleanUrls": false,
  "rewrites": [
    {
      "source": "/login",
      "destination": "/auth/login.html"
    },
    {
      "source": "/signup",
      "destination": "/auth/signup.html"
    },
    {
      "source": "/share/:id",
      "destination": "/share.html?id=:id"
    },
    {
      "source": "/print",
      "destination": "/print.html"
    },
    {
      "source": "/dashboard",
      "destination": "/index.html"
    },
    {
      "source": "/error",
      "destination": "/error.html"
    }
  ],
  "routes": [
    {
      "src": "/(.*).html",
      "status": 404,
      "dest": "/error.html"
    }
  ]
}
